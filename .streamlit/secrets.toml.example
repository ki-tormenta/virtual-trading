# Streamlit Secrets 設定例
# このファイルを secrets.toml にコピーして値を入力してください
# secrets.toml は .gitignore に含まれており、Git にコミットされません

# Supabase 接続情報（Supabase ダッシュボード → Project Settings → API から取得）
SUPABASE_URL = "https://xxxxxxxxxxxx.supabase.co"
SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# PostgreSQL 接続 URL（Supabase ダッシュボード → Project Settings → Database から取得）
# "postgres://" は自動で "postgresql://" に変換されます
DATABASE_URL = "postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres"

# OAuth リダイレクト先（Streamlit Cloud のアプリ URL）
APP_URL = "https://your-app.streamlit.app"
