# 仮想売買アプリ 環境変数設定例
# このファイルを .env にコピーして値を変更してください

# ローカル開発時に認証をスキップする（true にすると user_id=1 固定）
SKIP_AUTH=true

# 初期資金（円）。デフォルト: 10,000,000
INITIAL_CASH=10000000

# データベースファイルのパス。デフォルト: data/trading.db（SQLite ローカル）
# DB_PATH=data/trading.db

# 本番 PostgreSQL URL（Supabase の場合は Streamlit Secrets で管理推奨）
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Supabase（本番のみ。ローカルでは不要）
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OAuth リダイレクト先 URL（本番 Streamlit Cloud のURL）
# APP_URL=https://your-app.streamlit.app

# アプリ表示名
# APP_TITLE=仮想売買アプリ

# 株価取得リトライ設定
# PRICE_FETCH_RETRY_MAX=3
# PRICE_FETCH_RETRY_BACKOFF=1.5
